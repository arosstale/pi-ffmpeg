{
  "name": "pi-ffmpeg",
  "version": "1.0.3",
  "description": "ffmpeg Swiss Army knife for pi — probe, transcode, trim, concat, GIF, frames, audio extract/mux, thumbnail, compress, speedup/slowdown",
  "type": "module",
  "license": "MIT",
  "author": "artale",
  "repository": {
    "type": "git",
    "url": "https://github.com/arosstale/pi-ffmpeg"
  },
  "keywords": [
    "pi-package",
    "ffmpeg",
    "video",
    "audio",
    "transcode",
    "gif"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "commands": [
      "ffprobe",
      "ffmpeg",
      "transcode",
      "trim",
      "concat",
      "gif",
      "frames",
      "thumbnail",
      "extractaudio",
      "addaudio",
      "compress",
      "speed",
      "ffmpeg-help"
    ],
    "tools": [
      "ffmpeg_probe",
      "ffmpeg_transcode",
      "ffmpeg_trim",
      "ffmpeg_concat",
      "ffmpeg_gif",
      "ffmpeg_frames",
      "ffmpeg_thumbnail",
      "ffmpeg_extract_audio",
      "ffmpeg_add_audio",
      "ffmpeg_compress",
      "ffmpeg_speed",
      "ffmpeg_raw"
    ]
  },
  "files": [
    "extensions/",
    "README.md"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.56.0",
    "@sinclair/typebox": ">=0.34.0"
  }
}
